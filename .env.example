# Public site URL (no trailing slash). Used for return/cancel redirects.
# For production, set this to your canonical domain.
NEXT_PUBLIC_APP_URL=https://sealinkapp.com

# Payments: PayPal only (beta simplicity).

# Authorised voucher codes only you configure (JSON: CODE -> percent off 0–100).
# Example: 25% off with FRIEND25, or 100% off with COMP100.
VOUCHER_CODES={"DEMO25":25,"FULL100":100}

# Optional: OpenAI — 48-hour narrative outlook on the map page (server-side key only; never commit real keys).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Optional: custom base URL (Azure OpenAI, proxy, OpenRouter-compatible, etc.) — no trailing slash; /v1 added if missing is not applied; use full API root e.g. https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: PayPal (for one-off purchases like vessel classifieds)
# PAYPAL_ENV=sandbox            # sandbox | live
# PAYPAL_CLIENT_ID=AYQzBZPyRUTzPXFiFEG88xUs0RfSvzN6bwiys6X4Z8IbV0Y7l3cHlYV_b1Jrisn2MqgEt96G-Rj7kqIy
# PAYPAL_SECRET=ELGWeYjlHVrT8Iz32jAdPp9kawK4cN__XO1BVmqZGk1dLxkxjaNO_ynHGVMU84Dmv2iLjGRTOXg-hLaN
# PayPal subscriptions (plans must be created in PayPal dashboard with matching trial/billing rules)
# PAYPAL_PLAN_MONTHLY=P-8UF65267BN792864KNHZSZLQ
# PAYPAL_PLAN_ANNUAL=P-8PF91526KW306045MNHZS3ZQ

# WorldTides (tide extremes / hi-lo tide table)
# Register: https://www.worldtides.info/register
# WORLD_TIDES_API_KEY=your_key_here

# Meteostat via RapidAPI (nearest weather station observations)
# RapidAPI app: https://rapidapi.com/meteostat/api/meteostat/
# METEOSTAT_RAPIDAPI_KEY=your_key_here

# Optional: admin override email
# SEALINK_ADMIN_EMAIL=pyrotech999@hotmail.co.uk

# Optional: /gear marketplace — listing lifetime and in-app reminder window (days).
# GEAR_LISTING_TTL_DAYS=60
# GEAR_REMINDER_DAYS_BEFORE=7

# Optional: home map “nearby” sharing — radius (statute miles) and heartbeat stale window (seconds).
# MAP_NEARBY_RADIUS_MI=5
# MAP_PRESENCE_STALE_SEC=120

# Optional: area broadcasts — retention window (hours) and max posts per hour per browser session.
# MAP_BROADCAST_RETENTION_HOURS=24
